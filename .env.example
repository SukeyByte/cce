# Example environment configuration for cce
# Copy this file and rename to <name>.env

# Provider name (e.g., anthropic, deepseek, openai, zhipu)
CCE_PROVIDER=deepseek

# Model name
CCE_MODEL=deepseek-chat

# API Key
ANTHROPIC_API_KEY=sk-your-api-key-here

# API Base URL
ANTHROPIC_BASE_URL=https://api.deepseek.com/v1

# Optional: Custom claude binary path
# CCE_CLAUDE_BIN=/usr/local/bin/claude

# Optional: Extra environment variables (space-separated)
# CCE_EXTRA_ENV="KEY1=value1 KEY2=value2"
